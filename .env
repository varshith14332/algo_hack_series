# Algorand (public testnet nodes — no key needed)
ALGORAND_NODE_URL=https://testnet-api.algonode.cloud
ALGORAND_INDEXER_URL=https://testnet-idx.algonode.cloud
ALGORAND_NETWORK=testnet
ESCROW_CONTRACT_APP_ID=0
REPUTATION_CONTRACT_APP_ID=0
MARKETPLACE_CONTRACT_APP_ID=0
ORACLE_MNEMONIC=
ORACLE_ADDRESS=

# AI — using local Ollama model
OPENAI_API_KEY=ollama
OPENAI_EMBEDDING_MODEL=nomic-embed-text
OPENAI_CHAT_MODEL=llama3.2
OPENAI_BASE_URL=http://host.docker.internal:11434/v1

# Vector DB — add your Pinecone key here
PINECONE_API_KEY=
PINECONE_INDEX_NAME=neuralledger-cache
PINECONE_ENVIRONMENT=

# Storage — add Web3.Storage token here
WEB3_STORAGE_TOKEN=
IPFS_GATEWAY=https://w3s.link/ipfs/

# Database (Docker Compose local)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/neuralledger
REDIS_URL=redis://localhost:6379/0

# App
SECRET_KEY=neuralledger-dev-secret-key-change-in-production
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
VITE_BACKEND_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
VITE_ALGORAND_NODE_URL=https://testnet-api.algonode.cloud

# Pricing / thresholds
CACHE_SIMILARITY_THRESHOLD=0.85
NEW_TASK_PRICE_ALGO=0.005
CACHED_TASK_PRICE_ALGO=0.001
PLATFORM_REVENUE_SHARE=0.70
REQUESTER_REVENUE_SHARE=0.30
MAX_VERIFIER_RETRIES=2

# Agent Economy
MASTER_AGENT_SECRET=c15ea381b9ca8887a4ea237abb0e046a7590a6dcf251a1f39c3cc85562369d12
IDENTITY_CONTRACT_APP_ID=0
SERVICE_REGISTRY_CONTRACT_APP_ID=0
MIN_AGENT_REPUTATION=700
MASTER_AGENT_FUND_AMOUNT=2.0
