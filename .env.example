# Agent Economy
MASTER_AGENT_SECRET=          # Random 32-byte hex. Used to derive all agent wallets deterministically
IDENTITY_CONTRACT_APP_ID=     # From deploy step
SERVICE_REGISTRY_CONTRACT_APP_ID=  # From deploy step
MIN_AGENT_REPUTATION=700      # Minimum reputation score for BuyerAgent to use a service
MASTER_AGENT_FUND_AMOUNT=2.0  # How much ALGO to auto-fund master agent on first run
